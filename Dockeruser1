FROM debian:13

ENV DEBIAN_FRONTEND=noninteractive

RUN apt update -y && \
    apt upgrade -y && \
    apt install -y openssh-server wget tar

RUN wget -O bore.tar.gz https://github.com/ekzhang/bore/releases/download/v0.6.0/bore-v0.6.0-x86_64-unknown-linux-musl.tar.gz && \
    tar -xzf bore.tar.gz && \
    chmod +x bore && \
    mv bore /usr/local/bin/bore && \
    rm -f bore.tar.gz

RUN mkdir -p /run/sshd && \
    echo "PermitRootLogin yes" >> /etc/ssh/sshd_config && \
    echo "PasswordAuthentication yes" >> /etc/ssh/sshd_config && \
    echo "root:root" | chpasswd

RUN service ssh start

EXPOSE 22

CMD ["bore", "local", "22", "--to", "bore.pub"]
