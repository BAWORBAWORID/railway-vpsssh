FROM debian:13

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Jakarta

LABEL maintainer="alwayscodex"

WORKDIR /root

RUN apt update -y && apt upgrade -y && apt install -y locales curl wget unzip openssh-server gnupg lsb-release && localedef -i en_US -c -f UTF-8 -A /usr/share/locale/locale.alias en_US.UTF-8

#Install Bore

RUN wget -O bore.tar.gz https://github.com/ekzhang/bore/releases/download/v0.6.0/bore-v0.6.0-x86_64-unknown-linux-musl.tar.gz && \
tar -xzf bore.tar.gz && \
chmod +x bore && \
mv bore /usr/local/bin/bore && \
rm -f bore.tar.gz

SSH Configuration

RUN mkdir -p /run/sshd && 
echo "PermitRootLogin yes" >> /etc/ssh/sshd_config && 
echo "PasswordAuthentication yes" >> /etc/ssh/sshd_config && 
echo "root:root" | chpasswd

EXPOSE 22 80 443 8080 8888 3306

CMD ["/bin/bash", "-c", "/usr/sbin/sshd -D & bore local 22 --to bore.pub"]
