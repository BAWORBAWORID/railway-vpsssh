FROM debian:13

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Jakarta

LABEL maintainer="alwayscodex"

WORKDIR /root

RUN apt update -y && \
    apt upgrade -y && \
    apt install -y locales curl wget unzip openssh-server gnupg lsb-release && \
    localedef -i en_US -c -f UTF-8 -A /usr/share/locale/locale.alias en_US.UTF-8

# Install cloudflared
RUN mkdir -p --mode=0755 /usr/share/keyrings && \
    curl -fsSL https://pkg.cloudflare.com/cloudflare-public-v2.gpg \
    -o /usr/share/keyrings/cloudflare-public-v2.gpg && \
    echo "deb [signed-by=/usr/share/keyrings/cloudflare-public-v2.gpg] https://pkg.cloudflare.com/cloudflared any main" \
    > /etc/apt/sources.list.d/cloudflared.list && \
    apt update && \
    apt install -y cloudflared

# SSH Configuration
RUN mkdir -p /run/sshd

RUN echo 'PermitRootLogin yes' >> /etc/ssh/sshd_config
RUN echo 'PasswordAuthentication yes' >> /etc/ssh/sshd_config

RUN echo root:root | chpasswd

# Startup Script
RUN cat > /root/start.sh << 'EOF'
#!/bin/bash

service ssh start

cloudflared service install eyJhIjoiZWE1NjQ5MjNiMWJhYmZlODk1NmY1Y2UxOTNjNjRjYTkiLCJ0IjoiOTc1NDkwODgtNDQ4MC00NWI2LTg4MjgtZjAyMWFlOTRkOGFhIiwicyI6Ik56UXdZV05tWkdRdFpUa3dOaTAwTnpjMkxXRTFNVGN0WVRsbFpEVXpOVGczWmpoaSJ9

/usr/sbin/sshd -D
EOF

RUN chmod +x /root/start.sh

EXPOSE 22 80 443 8080 8888 3306

CMD ["/root/start.sh"]
